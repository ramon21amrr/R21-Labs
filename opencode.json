{
    "$schema": "https://opencode.ai/config.json",
    "shell": "pwsh",
    "share": "disabled",
    "autoupdate": false,
    "snapshot": true,
    "model": "zai-coding-plan/glm-5.2",
    "small_model": "zai-coding-plan/glm-4.7",
    "default_agent": "lvfi-builder",
    "subagent_depth": 1,
    "enabled_providers": ["zai-coding-plan"],
    "provider": {
        "zai-coding-plan": {
            "options": {
                "baseURL": "https://api.z.ai/api/coding/paas/v4",
                "timeout": 600000,
            }
        }
    },
    "watcher": {
        "ignore": [
            ".git/**",
            "**/.venv/**",
            "**/__pycache__/**",
            "**/.mypy_cache/**",
            "**/.ruff_cache/**",
            "**/.hypothesis/**",
            "**/build/**",
            "**/dist/**",
            "**/node_modules/**",
            "graphify-out/**",
            "inputs/**",
        ]
    },
    "permission": {
        "*": "ask",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow",
            "**/auth.json": "deny",
            "**/*credential*": "deny",
            "**/*.pem": "deny",
            "**/*.key": "deny",
            "**/*.p12": "deny",
            "**/*.pfx": "deny",
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "skill": "allow",
        "edit": "ask",
        "external_directory": "ask",
        "webfetch": "ask",
        "websearch": "ask",
        "bash": {
            "*": "ask",
            "git status*": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "git show*": "allow",
            "git branch --show-current*": "allow",
            "git rev-parse*": "allow",
            "git fetch*": "allow",
            "python -m pytest*": "allow",
            "py -m pytest*": "allow",
            "python -m ruff check*": "allow",
            "python -m ruff format --check*": "allow",
            "python -m mypy*": "allow",
            "python -m compileall*": "allow",
            "python -m pip check*": "allow",
            "graphify query*": "allow",
            "graphify path*": "allow",
            "graphify explain*": "allow",
            "graphify god-nodes*": "allow",
            "git add*": "ask",
            "git commit*": "ask",
            "git merge*": "ask",
            "git branch -d*": "ask",
            "git branch -D*": "deny",
            "git push*": "deny",
            "git reset --hard*": "deny",
            "git clean*": "deny",
            "git rebase main*": "deny",
            "git rebase origin/main*": "deny",
            "rm -rf*": "deny",
            "npm install -g*": "deny",
            "uv tool install*": "deny",
            "pip install*": "deny",
            "python -m pip install*": "deny",
            "py -m pip install*": "deny",
        },
    },
}
