LVFI_ENVIRONMENT=local
LVFI_APP_NAME=lvfi-api
LVFI_DEBUG=false
LVFI_HOST=127.0.0.1
LVFI_PORT=8000
LVFI_LOG_LEVEL=INFO
LVFI_DATABASE_URL=postgresql+asyncpg://lvfi:lvfi@127.0.0.1:5432/lvfi
LVFI_DATABASE_POOL_SIZE=5
LVFI_DATABASE_MAX_OVERFLOW=5
LVFI_DATABASE_TIMEOUT_SECONDS=5
LVFI_CORRELATION_HEADER=X-Request-ID
